COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DATABASE=mcp-db
KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Graph/vector path (query_graph). Optional — sensible defaults apply.
# EMBED_PROVIDER: hash (default, dependency-free, offline) | openai | local | passthrough
EMBED_PROVIDER=hash
# EMBED_DIM: query embedding dimension; keep aligned with stored node vectors.
EMBED_DIM=384
# Only for EMBED_PROVIDER=openai:
# OPENAI_API_KEY=your-openai-key
# OPENAI_EMBED_MODEL=text-embedding-3-small
